# =============================================================
# TMS — Environment Variable Template
# Copy this file to .env and fill in your values
# cp .env.example .env
# =============================================================

# --- PostgreSQL (Docker container) ---
POSTGRES_USER=tms_user
POSTGRES_PASSWORD=changeme
POSTGRES_DB=tms_local

# --- Backend ---
NODE_ENV=production
PORT=5000
DATABASE_URL=postgresql://tms_user:changeme@tms-postgres:5432/tms_local

# JWT
JWT_SECRET=replace_with_a_long_random_string
REFRESH_TOKEN_SECRET=replace_with_a_different_long_random_string
JWT_EXPIRIES_IN=30m
REFRESH_TOKEN_EXPIRES_IN=7d

# Face service URL (internal Docker network)
FACE_SERVICE_URL=http://tms-face-service:8000

# --- Face Service ---
FACE_RECOGNITION_THRESHOLD=0.4

# --- Frontend (build-time) ---
VITE_API_URL=http://localhost:5000

# --- Supabase (only needed if running in Supabase mode, not Docker DB mode) ---
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_KEY=your-service-role-key